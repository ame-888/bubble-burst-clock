                                        <div class="benchmark-cell score-cell athena-score" style="flex: 1;"><span class="athena-text">?</span></div>
                                    </div>
                                );
                                })}
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </main>
</Layout>

<style>
    main {
        max-width: 90rem; /* Wide layout */
        margin: 4rem auto;
        padding: 0 1rem;
    }

    h1 {
        font-size: 3rem;
        font-weight: 900;
        text-align: center;
        margin-bottom: 3rem;
        color: white;
        background: linear-gradient(to right, #F59E0B, #EF4444);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    h2 {
        font-size: 2rem;
        font-weight: 700;
        color: white;
        margin-bottom: 1.5rem;
        text-align: center;
    }

    /* Desktop layout overrides */
    .benchmark-desktop-container {
        display: block;
        width: 100%;
    }

    /* Scroll Container for Mobile */
    .benchmark-scroll-container {
        overflow-x: auto;
        padding-bottom: 1rem;
    }

    .benchmark-container {
        background: rgba(31, 41, 55, 0.5);
        border-radius: 1rem;
        padding: 1.5rem;
        box-shadow: 0 0 30px rgba(0,0,0,0.2);
        border: 1px solid rgba(245, 158, 11, 0.3);
        /* min-width: 900px;  Removed for responsive layout */
    }

    /* Unified Visual Grid */
    .unified-header-row, .unified-row {
        display: grid;
        grid-template-columns: minmax(60px, 2.5fr) repeat(6, minmax(25px, 1fr));
        gap: 0.1rem;
    }

    .data-table-wrapper .unified-header-row, .data-table-wrapper .unified-row {
        grid-template-columns: minmax(60px, 2.5fr) repeat(4, minmax(25px, 1fr));
    }

    @media (min-width: 640px) {
        .unified-header-row, .unified-row {
            gap: 0.5rem;
        }
    }

    .unified-row {
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    .unified-row:last-child {
        border-bottom: none;
    }

    /* Header Row */
    .header-row {
        /* No border bottom here, headers have their own style */
    }

    .col-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-end;
    }

    .col-header h3 {
        font-size: 0.5rem; /* Very small to fit on mobile */
        font-weight: 800;
        color: #F59E0B;
        margin-bottom: 0.25rem;
        border-bottom: 2px solid rgba(245, 158, 11, 0.3);
        padding-bottom: 0.2rem;
        text-align: center;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: inline-block;
    }

    .creature-icon {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 0.25rem;
        height: 24px;
    }

    @media (min-width: 640px) {
        .col-header h3 {
            font-size: 0.75rem;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
        }
    }

    @media (min-width: 1024px) {
        .col-header h3 {
            font-size: 0.85rem;
        }
    }

    .model-col-header h3 {
        text-align: left;
    }

    /* Benchmark Rows */
    .benchmark-row {
        border-bottom: 1px solid rgba(255, 255, 255, 0.1); /* Horizontal line */
    }

    /* Cells */
    .benchmark-cell {
        padding: 0.4rem 0.1rem; /* Very tight padding for mobile */
        display: flex;
        align-items: center;
    }

    @media (min-width: 640px) {
        .benchmark-cell {
            padding: 0.75rem 0.5rem;
        }
    }

    .model-cell {
        border-right: 1px solid rgba(255, 255, 255, 0.1);
        padding-right: 0.2rem;
    }

    @media (min-width: 640px) {
        .model-cell {
            padding-right: 1rem;
        }
    }

    .score-cell {
        justify-content: center;
        font-size: 0.6rem;
        font-weight: 900;
        text-align: center;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    @media (min-width: 640px) {
        .score-cell {
            font-size: 0.85rem;
        }
    }

    @media (min-width: 1024px) {
        .score-cell {
            font-size: 1rem;
        }
    }

    /* Content Layout inside Cell */
    .benchmark-content {
        display: flex;
        width: 100%;
        align-items: center;
        gap: 0.1rem; /* Reduced gap */
    }

    @media (min-width: 640px) {
        .benchmark-content {
            gap: 0.5rem;
        }
    }

    .rank {
        font-size: 0.6rem;
        font-weight: 900;
        color: #F59E0B;
        min-width: 15px;
        text-align: center;
    }

    @media (min-width: 640px) {
        .rank {
            font-size: 0.85rem;
            min-width: 20px;
        }
    }

    @media (min-width: 1024px) {
        .rank {
            font-size: 1rem;
            min-width: 25px;
        }
    }

    .fail-rank { color: #EF4444; font-size: 0.5rem; min-width: 40px; text-align: left; }

    @media (min-width: 640px) {
        .fail-rank { font-size: 0.7rem; min-width: 50px; }
    }

    @media (min-width: 1024px) {
        .fail-rank { font-size: 0.85rem; min-width: 70px; }
    }

    .model-info {
        flex: 1;
        min-width: 0; /* Text truncate */
    }

    .model-name {
        font-size: 0.6rem; /* Reduced font size to fit horizontally on mobile */
        font-weight: 600; /* Slightly lighter than card title */
        color: white;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    @media (min-width: 640px) {
        .model-name {
            font-size: 0.75rem;
        }
    }

    @media (min-width: 1024px) {
        .model-name {
            font-size: 0.85rem;
        }
    }

    .model-score {
        font-size: 1.1rem;
        font-weight: 900;
        color: #F59E0B;
        margin-left: auto;
    }

    .fail-score { color: #6B7280 !important; font-size: 0.85rem !important; text-shadow: none !important; }

    .zero-score-glow {
        text-shadow: 0 0 10px rgba(255, 0, 0, 0.8), 0 0 20px rgba(255, 0, 0, 0.6) !important;
        color: #ffcccc !important;
    }

    .best-score-glow {
        text-shadow: 0 0 20px rgba(255, 215, 0, 0.6), 0 0 40px rgba(255, 215, 0, 0.4) !important;
    }
    .fail-item .model-name { color: white; }

    /* --- MODEL BRANDING STYLES --- */
    .model-bg-gemini { background-color: #ADD8E6; }
    .model-bg-gemini .model-name { color: #111827; }
    .model-bg-gemini .rank { color: #111827; }
    .model-bg-gemini .model-score { color: #111827; }

    .model-bg-muse { background-color: #00008B; }
    .model-bg-muse .model-name { color: #FFFFFF; }
    .model-bg-muse .rank { color: #FFFFFF; }
    .model-bg-muse .model-score { color: #FFFFFF; }

    .model-bg-gpt { background-color: #90EE90; }
    .model-bg-gpt .model-name { color: #111827; }
    .model-bg-gpt .rank { color: #111827; }
    .model-bg-gpt .model-score { color: #111827; }

    .model-bg-grok { background-color: #FFD700; }
    .model-bg-grok .model-name { color: #111827; }
    .model-bg-grok .rank { color: #111827; }
    .model-bg-grok .model-score { color: #111827; }

    .model-bg-claude { background-color: #C8A2C8; }
    .model-bg-claude .model-name { color: #111827; }
    .model-bg-claude .rank { color: #111827; }
    .model-bg-claude .model-score { color: #111827; }

    /* --- CREATURE CHALLENGE STYLES --- */

    /* Mole (Earthy Brown) */
    .mole-header h3 { color: #A0522D; border-color: #A0522D; }
    .mole-score { color: #CD853F; }

    /* Rhino (Slate Grey) */
    .rhino-header h3 { color: #708090; border-color: #708090; }
    .rhino-score { color: #B0C4DE; }

    /* Chimpanzee (Jungle Green) */
    .chimp-header h3 { color: #2E8B57; border-color: #2E8B57; }
    .chimp-score { color: #3CB371; }

    /* Owl (Night Sky Blue) */
    .owl-header h3 { color: #4169E1; border-color: #4169E1; }
    .owl-score { color: #6495ED; }

    /* Eagle (Bright Sky Blue/Gold) */
    .eagle-header h3 { color: #00BFFF; border-color: #00BFFF; }
    .eagle-score { color: #87CEFA; }

    /* Beholder (Neon Arcane) */
    .beholder-header h3 {
        color: #FF00FF;
        text-shadow: 0 0 5px #FF00FF, 0 0 10px #8A2BE2, 0 0 20px #9400D3;
        border-color: #FF00FF;
        animation: arcanePulse 2s infinite alternate;
    }

    @keyframes arcanePulse {
        from { text-shadow: 0 0 5px #FF00FF, 0 0 10px #8A2BE2, 0 0 20px #9400D3; }
        to { text-shadow: 0 0 10px #FF00FF, 0 0 20px #8A2BE2, 0 0 30px #9400D3, 0 0 40px #4B0082; }
    }

    .beholder-score { color: #FF00FF; }
    .beholder-text { color: #FF69B4; text-shadow: 0 0 8px #FF1493; font-weight: 900; font-size: 1.2rem; }

    /* --- DATA CHALLENGE STYLES --- */

    /* Worm (Brown) */
    .worm-header h3 { color: #D2B48C; border-color: #D2B48C; }
    .worm-score { color: #DEB887; }

    /* Koala (Grey/Eucalyptus) */
    .koala-header h3 { color: #A9A9A9; border-color: #A9A9A9; }
    .koala-score { color: #8FBC8F; }

    /* Crow (Dark Grey/Black) */
    .crow-header h3 { color: #555555; border-color: #555555; }
    .crow-score { color: #777777; }

    /* Athena (Gold Theme Animation) */
    .athena-header h3 {
        color: #FFD700;
        border-color: #FFD700;
        text-shadow: 0 0 5px #FFD700, 0 0 10px #DAA520, 0 0 20px #B8860B;
        animation: athenaPulse 2s infinite alternate;
    }

    @keyframes athenaPulse {
        from { text-shadow: 0 0 5px #FFD700, 0 0 10px #DAA520, 0 0 20px #B8860B; }
        to { text-shadow: 0 0 10px #FFD700, 0 0 20px #DAA520, 0 0 30px #B8860B, 0 0 40px #8B6508; }
    }

    .athena-score { color: #FFD700; }
    .athena-text {
        color: #FFD700;
        text-shadow: 0 0 8px #DAA520;
        font-weight: 900;
        font-size: 1.2rem;
    }

    /* New Badge */
    .new-badge {
        display: inline-block;
        margin-left: 0.3rem;
        font-size: 0.6rem;
        font-weight: 800;
        color: #713f12;
        background: linear-gradient(135deg, #fcd34d 0%, #f59e0b 100%);
        padding: 0 0.3rem;
        border-radius: 0.2rem;
        text-transform: uppercase;
        box-shadow: 0 0 5px rgba(245, 158, 11, 0.5);
        animation: shine 2s infinite;
        vertical-align: middle;
        border: 1px solid #fbbf24;
    }

    @keyframes shine {
        0% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.8; transform: scale(1.05); }
        100% { opacity: 1; transform: scale(1); }
    }

    .disclaimer {
        margin-top: 2rem;
        font-size: 0.9rem;
        color: #9CA3AF;
        font-style: italic;
        text-align: center;
        opacity: 0.8;
    }

    /* Toggle Styles */
    .toggle-container {
        display: flex;
        justify-content: center;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .toggle-btn {
        background: rgba(31, 41, 55, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #9CA3AF;
        padding: 0.5rem 1.5rem;
        border-radius: 9999px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s ease;
        font-size: 1rem;
    }

    .toggle-btn:hover {
        background: rgba(255, 255, 255, 0.1);
        color: white;
    }

    .toggle-btn.active {
        background: #F59E0B;
        color: #1F2937;
        border-color: #F59E0B;
        box-shadow: 0 0 10px rgba(245, 158, 11, 0.4);
    }

    .hidden {
        display: none !important;
    }

    /* Coming Soon Styles */
    .coming-soon-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 400px;
        background: rgba(31, 41, 55, 0.5);
        border-radius: 1rem;
        border: 1px dashed rgba(245, 158, 11, 0.3);
        margin-top: 2rem;
    }

    .coming-soon-text {
        font-size: 3rem;
        font-weight: 900;
        color: rgba(255, 255, 255, 0.2);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        text-align: center;
    }

    .benchmark-description {
        max-width: 800px;
        margin: 0 auto 2rem auto;
        color: #D1D5DB;
        line-height: 1.6;
        font-size: 1.05rem;
        text-align: left;
        background: rgba(31, 41, 55, 0.4);
        padding: 1.5rem;
        border-radius: 0.75rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .benchmark-description p {
        margin-bottom: 1rem;
    }

    .benchmark-description p:last-child {
        margin-bottom: 0;
    }

    .benchmark-description ul {
        list-style-type: disc;
        margin-left: 2rem;
        margin-bottom: 1rem;
        color: #9CA3AF;
    }

    .benchmark-description li {
        margin-bottom: 0.25rem;
    }

    /* Data Benchmark Layout */
    .data-benchmark-layout {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        align-items: center;
    }

    @media (min-width: 1024px) {
        .data-benchmark-layout {
            flex-direction: row;
            align-items: flex-start;
            justify-content: center;
        }
        .data-table-wrapper {
            flex: 1;
            max-width: 1000px;
        }
        .data-warning-container {
            flex: 0 0 300px;
            margin-top: 0;
        }
    }

</style>

<script define:vars={{ TIME_OFFSET }}>
    function init() {
        const visualWrapper = document.getElementById('visual-benchmark-wrapper');
        const dataWrapper = document.getElementById('data-benchmark-wrapper');

        function updateBenchmarkView(mode) {
            if (mode === 'visual') {
                if (visualWrapper) visualWrapper.classList.remove('hidden');
                if (dataWrapper) dataWrapper.classList.add('hidden');
            } else {
                if (visualWrapper) visualWrapper.classList.add('hidden');
                if (dataWrapper) dataWrapper.classList.remove('hidden');
            }
            localStorage.setItem('benchmark_tab', mode);
        }

        // Listen for tab changes from the Navbar
        window.addEventListener('benchmarkTabChanged', (e) => {
            updateBenchmarkView(e.detail);
        });

        const urlParams = new URLSearchParams(window.location.search);
        const urlMode = urlParams.get('tab');
        const savedMode = urlMode || localStorage.getItem('benchmark_tab') || 'visual';
        updateBenchmarkView(savedMode);

        // --- Dynamic "NEW" Badge Logic ---
        const timeOffset = TIME_OFFSET;
        const simNow = new Date(new Date().getTime() + timeOffset);

        document.querySelectorAll('.model-name[data-release-date]').forEach(el => {
            const dateStr = el.getAttribute('data-release-date');
            if (!dateStr) return;

            const release = new Date(dateStr);
            // Reset hours
            release.setHours(0,0,0,0);
            const today = new Date(simNow);
            today.setHours(0,0,0,0);

            const diffTime = today.getTime() - release.getTime();
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

            // Should be new if within 30 days
            const isNew = diffDays >= -1 && diffDays <= 30;

            let badge = el.querySelector('.new-badge');
            if (isNew) {
                if (!badge) {
                    badge = document.createElement('span');
                    badge.className = 'new-badge';
                    badge.textContent = 'NEW';
                    el.appendChild(badge);
                }
            } else {
                if (badge) badge.remove();
            }
        });

        adjustFontSizes();
        window.addEventListener('resize', adjustFontSizes);
    }

    function adjustFontSizes() {
        const models = document.querySelectorAll('.model-name');
        models.forEach(el => {
            // Reset to original size to allow growth on resize
            el.style.fontSize = '0.85rem';

            let size = 0.85;
            const minSize = 0.50;

            // Reduce size while content overflows
            while (el.scrollWidth > el.clientWidth && size > minSize) {
                size -= 0.05;
                el.style.fontSize = `${size}rem`;
            }
        });
    }

    document.addEventListener('DOMContentLoaded', init);
</script>
