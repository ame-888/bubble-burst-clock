---
import Layout from '../layouts/Layout.astro';
import { benchmarks } from '../data/benchmarks';
import { getSimulatedDate, TIME_OFFSET } from '../scripts/TimeUtils';



// --- Simulated Time for Context ---
const SIMULATED_NOW = getSimulatedDate();

function isNew(dateStr) {
    if (!dateStr) return false;
    const release = new Date(dateStr);
    const now = new Date(SIMULATED_NOW);
    // Reset hours to compare just dates
    release.setHours(0,0,0,0);
    now.setHours(0,0,0,0);

    const diffTime = now.getTime() - release.getTime();
    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

    // Show new for items released in the last 30 days
    return diffDays >= -1 && diffDays <= 30;
}

function getModelColorClass(name) {
    const lowerName = name.toLowerCase();
    if (lowerName.includes('gemini')) return 'model-bg-gemini';
    if (lowerName.includes('muse')) return 'model-bg-muse';
    if (lowerName.includes('gpt')) return 'model-bg-gpt';
    if (lowerName.includes('grok')) return 'model-bg-grok';
    if (lowerName.includes('claude')) return 'model-bg-claude';
    return '';
}

// --- Ranking Logic ---
function computeRanks(items, scoreKeys) {
    const keys = Array.isArray(scoreKeys) ? scoreKeys : [scoreKeys];

    // 1. Sort
    let sorted = [...items].sort((a, b) => {
        for (const key of keys) {
            const valA = typeof a[key] === 'number' ? a[key] : 0;
            const valB = typeof b[key] === 'number' ? b[key] : 0;
            if (valB !== valA) {
                return valB - valA;
            }
        }
        return 0;
    });

    // 2. Separate Zeroes
    // A model is an "INVALID" if ALL its scores for the provided keys are 0
    const eligible = sorted.filter(i => keys.some(key => (typeof i[key] === 'number' ? i[key] : 0) > 0));
    const fails = sorted.filter(i => keys.every(key => (typeof i[key] === 'number' ? i[key] : 0) === 0)).sort((a,b) => a.name.localeCompare(b.name));

    // 3. Assign ranks to eligible
    let currentRank = 1;
    let previousItem = null;
    let rankedItems = [];

    eligible.forEach((item) => {
        if (previousItem !== null) {
            let isWorse = false;
            for (const key of keys) {
                const itemVal = typeof item[key] === 'number' ? item[key] : 0;
                const prevVal = typeof previousItem[key] === 'number' ? previousItem[key] : 0;
                if (itemVal < prevVal) {
                    isWorse = true;
                    break;
                } else if (itemVal > prevVal) {
                    break;
                }
            }
            if (isWorse) {
                currentRank++;
            }
        }

        rankedItems.push({ ...item, rank: currentRank, isFail: false });
        previousItem = item;
    });

    // 4. Append Fails
    fails.forEach(item => {
        rankedItems.push({ ...item, rank: 'INVALID', isFail: true });
    });

    return rankedItems;
}


// --- Unify Benchmark Data for Visual Mode ---
const unifiedDataMap = new Map();

benchmarks.models.forEach(m => {
    unifiedDataMap.set(m.name, {
        name: m.name,
        releaseDate: m.releaseDate,
        lvl1: m.scores.lvl1,
        lvl2: m.scores.lvl2,
        lvl3: m.scores.lvl3,
        lvl4: m.scores.lvl4,
        lvl5: m.scores.lvl5,
        lvl6: '?'
    });
});



const unifiedRawList = Array.from(unifiedDataMap.values()).map(m => {
    let total = m.lvl1 + m.lvl2 + m.lvl3 + m.lvl4 + m.lvl5;
    // Average removed in favor of level-by-level fallback ranking

    // Determine overall fail (all scores 0)
    m.isTotalFail = (m.lvl1 ?? 0) === 0 && (m.lvl2 ?? 0) === 0 && (m.lvl3 ?? 0) === 0 && (m.lvl4 ?? 0) === 0 && (m.lvl5 ?? 0) === 0;

    return m;
});

const unifiedList = computeRanks(unifiedRawList, ['lvl1', 'lvl2', 'lvl3', 'lvl4', 'lvl5']);

// Calculate best AI scores for each column to apply the golden aura
const bestAiScores = { lvl1: -1, lvl2: -1, lvl3: -1, lvl4: -1, lvl5: -1 };
unifiedList.forEach(item => {
    if (!item.isTotalFail) {
        if (item.lvl1 !== undefined && item.lvl1 > bestAiScores.lvl1) bestAiScores.lvl1 = item.lvl1;
        if (item.lvl2 !== undefined && item.lvl2 > bestAiScores.lvl2) bestAiScores.lvl2 = item.lvl2;
        if (item.lvl3 !== undefined && item.lvl3 > bestAiScores.lvl3) bestAiScores.lvl3 = item.lvl3;
        if (item.lvl4 !== undefined && item.lvl4 > bestAiScores.lvl4) bestAiScores.lvl4 = item.lvl4;
        if (item.lvl5 !== undefined && item.lvl5 > bestAiScores.lvl5) bestAiScores.lvl5 = item.lvl5;
    }
});

const rows = Array.from({ length: unifiedList.length }, (_, i) => i);

// Data Retrieval Logic
const dataDataMap = new Map();

(benchmarks.dataRetrieval || []).forEach(m => {
    dataDataMap.set(m.name, {
        name: m.name,
        releaseDate: m.releaseDate,
        worm: m.scores?.worm,
        koala: m.scores?.koala,
        crow: m.scores?.crow,
        athena: '?'
    });
});

const dataRawList = Array.from(dataDataMap.values()).map(m => {
    const wormScore = typeof m.worm === 'number' ? m.worm : 0;
    const koalaScore = typeof m.koala === 'number' ? m.koala : 0;
    const crowScore = typeof m.crow === 'number' ? m.crow : 0;
    m.isTotalFail = wormScore === 0 && koalaScore === 0 && crowScore === 0;
    return m;
});

const dataList = computeRanks(dataRawList, ['worm', 'koala', 'crow']);

const bestDataAiScores = { worm: -1, koala: -1, crow: -1 };
dataList.forEach(item => {
    if (!item.isTotalFail) {
        if (typeof item.worm === 'number' && item.worm > bestDataAiScores.worm) bestDataAiScores.worm = item.worm;
        if (typeof item.koala === 'number' && item.koala > bestDataAiScores.koala) bestDataAiScores.koala = item.koala;
        if (typeof item.crow === 'number' && item.crow > bestDataAiScores.crow) bestDataAiScores.crow = item.crow;
    }
});

const rowsData = Array.from({ length: dataList.length }, (_, i) => i);

function getPixelMedal(rank) {
    let color1, color2, color3;
    if (rank === 1) { color1 = '#FFD700'; color2 = '#DAA520'; color3 = '#B8860B'; } // Gold
    else if (rank === 2) { color1 = '#E0E0E0'; color2 = '#C0C0C0'; color3 = '#A9A9A9'; } // Silver
    else if (rank === 3) { color1 = '#CD7F32'; color2 = '#A0522D'; color3 = '#8B4513'; } // Bronze

    return `<svg width="24" height="24" viewBox="0 0 16 16" style="display:inline-block; vertical-align:middle; filter:drop-shadow(0 2px 2px rgba(0,0,0,0.5));">
        <path d="M4 2 h8 v2 h-8 z" fill="${color3}"/>
        <path d="M3 4 h10 v8 h-10 z" fill="${color2}"/>
        <path d="M4 5 h8 v6 h-8 z" fill="${color1}"/>
        <path d="M5 6 h6 v4 h-6 z" fill="#FFFFFF" fill-opacity="0.3"/>
        <path d="M4 12 h8 v2 h-8 z" fill="${color3}"/>
        <text x="8" y="9" font-family="monospace" font-size="6" font-weight="bold" fill="${color3}" text-anchor="middle" dominant-baseline="central">${rank}</text>
    </svg>`;
}

function getRankDisplay(rank) {
    if (rank === '-') return '-';
    if (rank === 'INVALID') return 'INVALID';
    if (rank === 1) return getPixelMedal(1);
    if (rank === 2) return getPixelMedal(2);
    if (rank === 3) return getPixelMedal(3);
    return `#${rank}`;
}
---

