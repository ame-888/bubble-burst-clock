---
import Layout from '../layouts/Layout.astro';
import { benchmarks } from '../data/benchmarks';
import { getSimulatedDate, TIME_OFFSET } from '../scripts/TimeUtils';
const lang = 'en';

// --- Simulated Time for Context ---
const SIMULATED_NOW = getSimulatedDate();

function isNew(dateStr) {
    if (!dateStr) return false;
    const release = new Date(dateStr);
    const now = new Date(SIMULATED_NOW);
    // Reset hours to compare just dates
    release.setHours(0,0,0,0);
    now.setHours(0,0,0,0);

    const diffTime = now.getTime() - release.getTime();
    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

    // Show new for items released in the last 30 days
    return diffDays >= -1 && diffDays <= 30;
}

// --- Ranking Logic ---
function computeRanks(items, scoreKeys) {
    const keys = Array.isArray(scoreKeys) ? scoreKeys : [scoreKeys];

    // 1. Sort
    let sorted = [...items].sort((a, b) => {
        // Human Baseline always on top if it exists, though score usually handles it
        if (a.name === 'Human Baseline') return -1;
        if (b.name === 'Human Baseline') return 1;

        for (const key of keys) {
            const valA = a[key] ?? 0;
            const valB = b[key] ?? 0;
            if (valB !== valA) {
                return valB - valA;
            }
        }
        return 0;
    });

    // 2. Separate Zeroes
    // A model is an "EPIC FAIL" if ALL its scores for the provided keys are 0
    const eligible = sorted.filter(i => keys.some(key => (i[key] ?? 0) > 0));
    const fails = sorted.filter(i => keys.every(key => (i[key] ?? 0) === 0)).sort((a,b) => a.name.localeCompare(b.name));

    // 3. Assign ranks to eligible
    let currentRank = 1;
    let previousItem = null;
    let rankedItems = [];

    eligible.forEach((item) => {
        if (item.name === 'Human Baseline') {
            rankedItems.push({ ...item, rank: '-', isFail: false });
            return;
        }

        if (previousItem !== null) {
            let isWorse = false;
            for (const key of keys) {
                const itemVal = item[key] ?? 0;
                const prevVal = previousItem[key] ?? 0;
                if (itemVal < prevVal) {
                    isWorse = true;
                    break;
                } else if (itemVal > prevVal) {
                    break;
                }
            }
            if (isWorse) {
                currentRank++;
            }
        }

        rankedItems.push({ ...item, rank: currentRank, isFail: false });
        previousItem = item;
    });

    // 4. Append Fails
    fails.forEach(item => {
        rankedItems.push({ ...item, rank: 'EPIC FAIL', isFail: true });
    });

    return rankedItems;
}


// --- Unify Benchmark Data for Visual Mode ---
const unifiedDataMap = new Map();

benchmarks.models.forEach(m => {
    unifiedDataMap.set(m.name, {
        name: m.name,
        releaseDate: m.releaseDate,
        lvl1: m.scores.lvl1,
        lvl2: m.scores.lvl2,
        lvl3: m.scores.lvl3,
        lvl4: m.scores.lvl4,
        lvl5: m.scores.lvl5,
        lvl6: '?'
    });
});



const unifiedRawList = Array.from(unifiedDataMap.values()).map(m => {
    let total = m.lvl1 + m.lvl2 + m.lvl3 + m.lvl4 + m.lvl5;
    // Average removed in favor of level-by-level fallback ranking

    // Determine overall fail (all scores 0)
    m.isTotalFail = (m.lvl1 ?? 0) === 0 && (m.lvl2 ?? 0) === 0 && (m.lvl3 ?? 0) === 0 && (m.lvl4 ?? 0) === 0 && (m.lvl5 ?? 0) === 0;

    return m;
});

const unifiedList = computeRanks(unifiedRawList, ['lvl1', 'lvl2', 'lvl3', 'lvl4', 'lvl5']);
const rows = Array.from({ length: unifiedList.length }, (_, i) => i);

// Data Retrieval Logic
const dataList = computeRanks(benchmarks.dataRetrieval || [], 'score');
const rowsData = Array.from({ length: dataList.length }, (_, i) => i);

function getRankDisplay(rank) {
    if (rank === '-') return '-';
    if (rank === 'EPIC FAIL') return 'EPIC FAIL';
    if (rank === 1) return '🥇';
    if (rank === 2) return '🥈';
    if (rank === 3) return '🥉';
    return `#${rank}`;
}
---

<Layout lang={lang} title="OUR BENCHMARK - Ultimate Bench">
    <main>
        <h1 id="leaderboard-title">OUR BENCHMARK</h1>

        <div class="toggle-container">
            <button id="toggle-visual" class="toggle-btn active">VISUAL</button>
            <button id="toggle-data" class="toggle-btn">DATA</button>
        </div>

        <!-- Benchmark About Modal -->
        <div id="modal-overlay" class="hidden"></div>
        <div id="about-benchmark-modal" class="modal hidden">
            <div class="modal-content">
                <button class="close-modal">&times;</button>
                <h3 id="about-modal-title">About Benchmark</h3>
                <p id="about-modal-desc">Description here...</p>
            </div>
        </div>

        <div class="leaderboard-grid">
            <!-- Benchmarks Section -->
            <section class="leaderboard-section full-width">
                <div class="benchmark-header-container">
                    <h2 id="benchmark-title">Ultimate Visual Bench</h2>
                    <button id="about-benchmark-btn" class="about-benchmark-btn" title="ABOUT">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
                        </svg>
                        <span>ABOUT</span>
                    </button>
                </div>

                <div id="visual-benchmark-wrapper">
                    <div class="benchmark-desktop-container">
                        <div class="benchmark-container visual-table">
                            <!-- Header Row -->
                            <div class="header-row unified-header-row">
                                <div class="col-header model-col-header"><h3>MODEL</h3></div>
                                <div class="col-header mole-header"><h3>MOLE</h3></div>
                                <div class="col-header rhino-header"><h3>RHINO</h3></div>
                                <div class="col-header chimp-header"><h3>CHIMPANZEE</h3></div>
                                <div class="col-header owl-header"><h3>OWL</h3></div>
                                <div class="col-header eagle-header"><h3>EAGLE</h3></div>
                                <div class="col-header beholder-header"><h3>BEHOLDER</h3></div>
                            </div>

                            <!-- Rows Loop -->
                            {rows.map(i => {
                                const item = unifiedList[i];

                                return (
                                    <div class="benchmark-row unified-row">
                                        {/* Model Column */}
                                        <div class="benchmark-cell model-cell">
                                            <div class={`benchmark-content ${item.isTotalFail ? 'fail-item' : ''} ${item.name === 'Human Baseline' ? 'human-baseline' : ''}`}>
                                                <div class={`rank ${item.isTotalFail ? 'fail-rank' : ''}`}>
                                                    {getRankDisplay(item.rank)}
                                                </div>
                                                <div class="model-info">
                                                    <div class="model-name" data-release-date={item.releaseDate}>
                                                        {item.name}
                                                        {isNew(item.releaseDate) && <span class="new-badge">NEW</span>}
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        {/* Challenge Columns */}
                                        <div class="benchmark-cell score-cell mole-score"><span class={`${item.isTotalFail ? 'fail-score' : ''}`}>{item.name === 'Human Baseline' ? '100%' : (item.isTotalFail ? 'EPIC FAIL' : (item.lvl1 !== undefined ? `${item.lvl1}%` : ''))}</span></div>
                                        <div class="benchmark-cell score-cell rhino-score"><span class={`${item.isTotalFail ? 'fail-score' : ''}`}>{item.name === 'Human Baseline' ? '100%' : (item.isTotalFail ? 'EPIC FAIL' : (item.lvl2 !== undefined ? `${item.lvl2}%` : ''))}</span></div>
                                        <div class="benchmark-cell score-cell chimp-score"><span class={`${item.isTotalFail ? 'fail-score' : ''}`}>{item.name === 'Human Baseline' ? '100%' : (item.isTotalFail ? 'EPIC FAIL' : (item.lvl3 !== undefined ? `${item.lvl3}%` : ''))}</span></div>
                                        <div class="benchmark-cell score-cell owl-score"><span class={`${item.isTotalFail ? 'fail-score' : ''}`}>{item.name === 'Human Baseline' ? '100%' : (item.isTotalFail ? 'EPIC FAIL' : (item.lvl4 !== undefined ? `${item.lvl4}%` : ''))}</span></div>
                                        <div class="benchmark-cell score-cell eagle-score"><span class={`${item.isTotalFail ? 'fail-score' : ''}`}>{item.name === 'Human Baseline' ? '100%' : (item.isTotalFail ? 'EPIC FAIL' : (item.lvl5 !== undefined ? `${item.lvl5}%` : ''))}</span></div>
                                        <div class="benchmark-cell score-cell beholder-score"><span class="beholder-text">{item.name === 'Human Baseline' ? '' : '?'}</span></div>
                                    </div>
                                );
                            })}

                            <p class="disclaimer">* This specific model had a FAILED STATE over 50%. A FAILED STATE means the model failed to answer the questions at all, even if incorrectly. Other models did present this behavior ocasionally, but nowhere near this often. A high frequency of FAILED STATE shows a fundamental issue in understanding user intent. While the model did perform decently when it did understand the questions, we decided the abundance of FAILED STATE is enough to consider it below the minimum criteria</p>
                        </div>
                    </div>
                </div>

                <div id="data-benchmark-wrapper" class="hidden">
                    <div class="data-benchmark-layout">
                        <div class="benchmark-scroll-container data-table-wrapper">
                            <div class="benchmark-container single-col-container">
                                <!-- Header Row -->
                                <div class="header-row single-col-header">
                                    <div class="col-header"><h3>SCORE</h3></div>
                                </div>

                                <!-- Rows Loop -->
                                {rowsData.map(i => {
                                const item = dataList[i];
                                return (
                                    <div class="benchmark-row single-col-row">
                                        <div class="benchmark-cell">
                                            {item && (
                                                <div class={`benchmark-content ${item.isFail ? 'fail-item' : ''} ${item.name === 'Human Baseline' ? 'human-baseline' : ''}`}>
                                                    <div class={`rank ${item.isFail ? 'fail-rank' : ''}`}>
                                                        {getRankDisplay(item.rank)}
                                                    </div>
                                                    <div class="model-info">
                                                        <div class="model-name" data-release-date={item.releaseDate}>
                                                            {item.name}
                                                            {isNew(item.releaseDate) && <span class="new-badge">NEW</span>}
                                                        </div>
                                                    </div>
                                                        <div class={`model-score ${item.isFail ? 'fail-score' : ''}`}>{item.score}%</div>
                                                    </div>
                                                )}
                                            </div>
                                        </div>
                                    );
                                })}

                                <p class="disclaimer" id="data-benchmark-disclaimer">In order to make this benchmark stay unsaturated for longer, easier questions might be removed and harder questions might be added over time. Any changes will be applied on all models, in order to make things fair</p>
                            </div>
                        </div>

                        <!-- Warning Section -->
                        <div class="data-warning-container">
                            <div class="warning-box">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="warning-icon">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                </svg>
                                <p id="data-benchmark-warning">Warning: A Hard Mode will be added when a model gets a score over 50%</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </main>
</Layout>

<style>
    main {
        max-width: 90rem; /* Wide layout */
        margin: 4rem auto;
        padding: 0 1rem;
    }

    h1 {
        font-size: 3rem;
        font-weight: 900;
        text-align: center;
        margin-bottom: 3rem;
        color: white;
        background: linear-gradient(to right, #F59E0B, #EF4444);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    h2 {
        font-size: 2rem;
        font-weight: 700;
        color: white;
        margin-bottom: 1.5rem;
        text-align: center;
    }

    /* Desktop layout overrides */
    .benchmark-desktop-container {
        display: block;
        width: 100%;
    }

    /* Scroll Container for Mobile */
    .benchmark-scroll-container {
        overflow-x: auto;
        padding-bottom: 1rem;
    }

    .benchmark-container {
        background: var(--benchmark-bg, rgba(31, 41, 55, 0.5));
        border-radius: 1rem;
        padding: 1.5rem;
        box-shadow: 0 0 30px rgba(0,0,0,0.2);
        border: 1px solid rgba(245, 158, 11, 0.3);
        /* min-width: 900px;  Removed for responsive layout */
    }

    /* Unified Visual Grid */
    .unified-header-row, .unified-row {
        display: grid;
        grid-template-columns: minmax(60px, 2.5fr) repeat(6, minmax(25px, 1fr));
        gap: 0.1rem;
    }

    @media (min-width: 640px) {
        .unified-header-row, .unified-row {
            gap: 0.5rem;
        }
    }

    .unified-row {
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    .unified-row:last-child {
        border-bottom: none;
    }

    /* Header Row */
    .header-row {
        /* No border bottom here, headers have their own style */
    }

    .col-header h3 {
        font-size: 0.5rem; /* Very small to fit on mobile */
        font-weight: 800;
        color: #F59E0B;
        margin-bottom: 0.5rem;
        border-bottom: 2px solid rgba(245, 158, 11, 0.3);
        padding-bottom: 0.2rem;
        text-align: center;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    @media (min-width: 640px) {
        .col-header h3 {
            font-size: 0.75rem;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
        }
    }

    @media (min-width: 1024px) {
        .col-header h3 {
            font-size: 0.85rem;
        }
    }

    .model-col-header h3 {
        text-align: left;
    }

    /* Benchmark Rows */
    .benchmark-row {
        border-bottom: 1px solid rgba(255, 255, 255, 0.1); /* Horizontal line */
    }

    /* Cells */
    .benchmark-cell {
        padding: 0.4rem 0.1rem; /* Very tight padding for mobile */
        display: flex;
        align-items: center;
    }

    @media (min-width: 640px) {
        .benchmark-cell {
            padding: 0.75rem 0.5rem;
        }
    }

    .model-cell {
        border-right: 1px solid rgba(255, 255, 255, 0.1);
        padding-right: 0.2rem;
    }

    @media (min-width: 640px) {
        .model-cell {
            padding-right: 1rem;
        }
    }

    .score-cell {
        justify-content: center;
        font-size: 0.6rem;
        font-weight: 900;
        text-align: center;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    @media (min-width: 640px) {
        .score-cell {
            font-size: 0.85rem;
        }
    }

    @media (min-width: 1024px) {
        .score-cell {
            font-size: 1rem;
        }
    }

    /* Content Layout inside Cell */
    .benchmark-content {
        display: flex;
        width: 100%;
        align-items: center;
        gap: 0.1rem; /* Reduced gap */
    }

    @media (min-width: 640px) {
        .benchmark-content {
            gap: 0.5rem;
        }
    }

    .rank {
        font-size: 0.6rem;
        font-weight: 900;
        color: #F59E0B;
        min-width: 15px;
        text-align: center;
    }

    @media (min-width: 640px) {
        .rank {
            font-size: 0.85rem;
            min-width: 20px;
        }
    }

    @media (min-width: 1024px) {
        .rank {
            font-size: 1rem;
            min-width: 25px;
        }
    }

    .human-baseline { opacity: 0.8; }
    .human-baseline .rank { color: #9CA3AF; }
    .fail-rank { color: #EF4444; font-size: 0.5rem; min-width: 40px; text-align: left; }

    @media (min-width: 640px) {
        .fail-rank { font-size: 0.7rem; min-width: 50px; }
    }

    @media (min-width: 1024px) {
        .fail-rank { font-size: 0.85rem; min-width: 70px; }
    }

    .model-info {
        flex: 1;
        min-width: 0; /* Text truncate */
    }

    .model-name {
        font-size: 0.6rem; /* Reduced font size to fit horizontally on mobile */
        font-weight: 600; /* Slightly lighter than card title */
        color: white;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    @media (min-width: 640px) {
        .model-name {
            font-size: 0.75rem;
        }
    }

    @media (min-width: 1024px) {
        .model-name {
            font-size: 0.85rem;
        }
    }

    .model-score {
        font-size: 1.1rem;
        font-weight: 900;
        color: #F59E0B;
        margin-left: auto;
    }

    .fail-score { color: #6B7280 !important; font-size: 0.85rem !important; text-shadow: none !important; }
    .fail-item .model-name { color: white; }

    /* --- CREATURE CHALLENGE STYLES --- */

    /* Mole (Earthy Brown) */
    .mole-header h3 { color: #A0522D; border-color: #A0522D; }
    .mole-score { color: #CD853F; }

    /* Rhino (Slate Grey) */
    .rhino-header h3 { color: #708090; border-color: #708090; }
    .rhino-score { color: #B0C4DE; }

    /* Chimpanzee (Jungle Green) */
    .chimp-header h3 { color: #2E8B57; border-color: #2E8B57; }
    .chimp-score { color: #3CB371; }

    /* Owl (Night Sky Blue) */
    .owl-header h3 { color: #4169E1; border-color: #4169E1; }
    .owl-score { color: #6495ED; }

    /* Eagle (Bright Sky Blue/Gold) */
    .eagle-header h3 { color: #00BFFF; border-color: #00BFFF; }
    .eagle-score { color: #87CEFA; }

    /* Beholder (Neon Arcane) */
    .beholder-header h3 {
        color: #FF00FF;
        text-shadow: 0 0 5px #FF00FF, 0 0 10px #8A2BE2, 0 0 20px #9400D3;
        border-color: #FF00FF;
        animation: arcanePulse 2s infinite alternate;
    }

    @keyframes arcanePulse {
        from { text-shadow: 0 0 5px #FF00FF, 0 0 10px #8A2BE2, 0 0 20px #9400D3; }
        to { text-shadow: 0 0 10px #FF00FF, 0 0 20px #8A2BE2, 0 0 30px #9400D3, 0 0 40px #4B0082; }
    }

    .beholder-score { color: #FF00FF; }
    .beholder-text { color: #FF69B4; text-shadow: 0 0 8px #FF1493; font-weight: 900; font-size: 1.2rem; }

    /* New Badge */
    .new-badge {
        display: inline-block;
        margin-left: 0.3rem;
        font-size: 0.6rem;
        font-weight: 800;
        color: #713f12;
        background: linear-gradient(135deg, #fcd34d 0%, #f59e0b 100%);
        padding: 0 0.3rem;
        border-radius: 0.2rem;
        text-transform: uppercase;
        box-shadow: 0 0 5px rgba(245, 158, 11, 0.5);
        animation: shine 2s infinite;
        vertical-align: middle;
        border: 1px solid #fbbf24;
    }

    @keyframes shine {
        0% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.8; transform: scale(1.05); }
        100% { opacity: 1; transform: scale(1); }
    }

    .disclaimer {
        margin-top: 2rem;
        font-size: 0.9rem;
        color: #9CA3AF;
        font-style: italic;
        text-align: center;
        opacity: 0.8;
    }

    /* Toggle Styles */
    .toggle-container {
        display: flex;
        justify-content: center;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .toggle-btn {
        background: var(--benchmark-bg, rgba(31, 41, 55, 0.5));
        border: 1px solid rgba(156, 163, 175, 0.5);
        color: var(--color-text, #9CA3AF);
        padding: 0.5rem 1.5rem;
        border-radius: 9999px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s ease;
        font-size: 1rem;
    }

    .toggle-btn:hover {
        background: rgba(156, 163, 175, 0.2);
        color: var(--color-text, white);
    }

    .toggle-btn.active {
        background: #F59E0B;
        color: #1F2937;
        border-color: #F59E0B;
        box-shadow: 0 0 10px rgba(245, 158, 11, 0.4);
    }

    .hidden {
        display: none !important;
    }

    /* Coming Soon Styles */
    .coming-soon-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 400px;
        background: rgba(31, 41, 55, 0.5);
        border-radius: 1rem;
        border: 1px dashed rgba(245, 158, 11, 0.3);
        margin-top: 2rem;
    }

    .coming-soon-text {
        font-size: 3rem;
        font-weight: 900;
        color: rgba(255, 255, 255, 0.2);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        text-align: center;
    }

    /* Header Container */
    .benchmark-header-container {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .benchmark-header-container h2 {
        margin-bottom: 0;
    }

    .about-benchmark-btn {
        background: none;
        border: none;
        color: #6B7280;
        cursor: pointer;
        transition: color 0.2s;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem;
    }
    .about-benchmark-btn:hover {
        color: #F59E0B;
    }
    .about-benchmark-btn svg {
        width: 1.5rem;
        height: 1.5rem;
    }
    .about-benchmark-btn span {
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
        display: none;
    }
    @media (min-width: 640px) {
        .about-benchmark-btn span {
            display: inline;
        }
    }

    /* Single Column Layout */
    .benchmark-container.single-col-container {
        min-width: auto;
        max-width: 600px;
        margin: 0 auto;
    }

    .header-row.single-col-header,
    .benchmark-row.single-col-row {
        grid-template-columns: 1fr;
    }

    .single-col-row .benchmark-cell {
        border-right: none;
    }

    /* Data Benchmark Layout */
    .data-benchmark-layout {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        align-items: center;
    }

    @media (min-width: 1024px) {
        .data-benchmark-layout {
            flex-direction: row;
            align-items: flex-start;
            justify-content: center;
        }
        .data-table-wrapper {
            flex: 1;
            max-width: 600px;
        }
        .data-warning-container {
            flex: 0 0 300px;
            margin-top: 0;
        }
    }

    /* Warning Box */
    .data-warning-container {
        width: 100%;
        max-width: 600px;
    }

    .warning-box {
        background: rgba(239, 68, 68, 0.1);
        border: 2px solid rgba(239, 68, 68, 0.6);
        border-radius: 1rem;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 1rem;
        box-shadow: 0 0 20px rgba(239, 68, 68, 0.2);
    }

    .warning-icon {
        width: 3rem;
        height: 3rem;
        color: #ef4444;
        animation: pulseRed 2s infinite;
    }

    @keyframes pulseRed {
        0% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.1); opacity: 0.8; }
        100% { transform: scale(1); opacity: 1; }
    }

    #data-benchmark-warning {
        color: #fca5a5;
        font-weight: 700;
        font-size: 1.1rem;
        line-height: 1.4;
        margin: 0;
    }

    /* Modal Styles */
    #modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: blur(5px);
        z-index: 20000;
        animation: fadeIn 0.3s;
    }

    .modal {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 20001;
        width: 90%;
        max-width: 600px;
        animation: slideIn 0.3s cubic-bezier(0.18, 0.89, 0.32, 1.28);
    }

    .modal-content {
        background: #1F2937;
        padding: 2.5rem;
        border-radius: 1.5rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        position: relative;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }

    .close-modal {
        position: absolute;
        top: 1rem;
        right: 1.5rem;
        background: none;
        border: none;
        color: #9CA3AF;
        font-size: 2rem;
        cursor: pointer;
        line-height: 1;
    }
    .close-modal:hover { color: white; }

    #about-modal-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #F59E0B;
        margin-bottom: 1rem;
        text-align: center;
    }

    #about-modal-desc {
        color: #D1D5DB;
        line-height: 1.6;
        text-align: center;
        font-size: 1rem;
    }

    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @keyframes slideIn { from { transform: translate(-50%, -45%); opacity: 0; } to { transform: translate(-50%, -50%); opacity: 1; } }
</style>

<script define:vars={{ lang, TIME_OFFSET }}>
    function init() {

        const mainTitle = document.getElementById('leaderboard-title');
        const benchTitle = document.getElementById('benchmark-title');
        const dataDisclaimer = document.getElementById('data-benchmark-disclaimer');
        const dataWarning = document.getElementById('data-benchmark-warning');

        const toggleVisual = document.getElementById('toggle-visual');
        const toggleData = document.getElementById('toggle-data');
        const visualWrapper = document.getElementById('visual-benchmark-wrapper');
        const dataWrapper = document.getElementById('data-benchmark-wrapper');
        const comingSoonText = document.querySelector('.coming-soon-text');


        function updateBenchmarkView(mode) {
            if (mode === 'visual') {
                if (toggleVisual) toggleVisual.classList.add('active');
                if (toggleData) toggleData.classList.remove('active');
                if (visualWrapper) visualWrapper.classList.remove('hidden');
                if (dataWrapper) dataWrapper.classList.add('hidden');
                if (benchTitle) benchTitle.textContent = "Ultimate Visual Bench";
            } else {
                if (toggleVisual) toggleVisual.classList.remove('active');
                if (toggleData) toggleData.classList.add('active');
                if (visualWrapper) visualWrapper.classList.add('hidden');
                if (dataWrapper) dataWrapper.classList.remove('hidden');
                if (benchTitle) benchTitle.textContent = "Data Retrieval Bench";
            }
            localStorage.setItem('benchmark_tab', mode);
        }

        if (toggleVisual) toggleVisual.addEventListener('click', () => updateBenchmarkView('visual'));
        if (toggleData) toggleData.addEventListener('click', () => updateBenchmarkView('data'));

        // --- About Modal Logic ---
        const modalOverlay = document.getElementById('modal-overlay');
        const aboutModal = document.getElementById('about-benchmark-modal');
        const aboutBtn = document.getElementById('about-benchmark-btn');
        const closeModalBtn = document.querySelector('.close-modal');
        const aboutTitle = document.getElementById('about-modal-title');
        const aboutDesc = document.getElementById('about-modal-desc');

        function openModal() {
             if (aboutModal && modalOverlay) {
                aboutModal.classList.remove('hidden');
                modalOverlay.classList.remove('hidden');

                // Set content based on active tab
                const isVisual = toggleVisual && toggleVisual.classList.contains('active');
                if (isVisual) {
                    if(aboutTitle) aboutTitle.textContent = "Ultimate Visual Bench";
                    if(aboutDesc) aboutDesc.textContent = "It is a collection of 5 levels: Mole, Rhino, Chimpanzee, Owl, Eagle. Each level includes visually intensive questions. Some questions require counting elements, matching them with logic, drawing paths, avoiding traps, executing 2D physics concepts on mind. These levels are designed to be impossible to guess, and to truly test the reasoning capabilities combined with the visual cortex.";
                } else {
                    if(aboutTitle) aboutTitle.textContent = "Data Retrieval Bench";
                    if(aboutDesc) aboutDesc.textContent = "The 'Data Retrieval Benchmark' evaluates an AI's ability to locate, extract, and accurately present specific factual information. It involves 10 deep questions with explicit, irrefutable answers, and the system is granted access to web search tools to assist in finding the data.";
                }
             }
        }

        function closeModal() {
            if (aboutModal && modalOverlay) {
                aboutModal.classList.add('hidden');
                modalOverlay.classList.add('hidden');
            }
        }

        if (aboutBtn) aboutBtn.addEventListener('click', openModal);
        if (closeModalBtn) closeModalBtn.addEventListener('click', closeModal);
        if (modalOverlay) modalOverlay.addEventListener('click', closeModal);

        const savedMode = localStorage.getItem('benchmark_tab') || 'visual';
        updateBenchmarkView(savedMode);

        // --- Dynamic "NEW" Badge Logic ---
        const timeOffset = TIME_OFFSET;
        const simNow = new Date(new Date().getTime() + timeOffset);

        document.querySelectorAll('.model-name[data-release-date]').forEach(el => {
            const dateStr = el.getAttribute('data-release-date');
            if (!dateStr) return;

            const release = new Date(dateStr);
            // Reset hours
            release.setHours(0,0,0,0);
            const today = new Date(simNow);
            today.setHours(0,0,0,0);

            const diffTime = today.getTime() - release.getTime();
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

            // Should be new if within 30 days
            const isNew = diffDays >= -1 && diffDays <= 30;

            let badge = el.querySelector('.new-badge');
            if (isNew) {
                if (!badge) {
                    badge = document.createElement('span');
                    badge.className = 'new-badge';
                    badge.textContent = 'NEW';
                    el.appendChild(badge);
                }
            } else {
                if (badge) badge.remove();
            }
        });

        adjustFontSizes();
        window.addEventListener('resize', adjustFontSizes);
    }

    function adjustFontSizes() {
        const models = document.querySelectorAll('.model-name');
        models.forEach(el => {
            // Reset to original size to allow growth on resize
            el.style.fontSize = '0.85rem';

            let size = 0.85;
            const minSize = 0.50;

            // Reduce size while content overflows
            while (el.scrollWidth > el.clientWidth && size > minSize) {
                size -= 0.05;
                el.style.fontSize = `${size}rem`;
            }
        });
    }

    document.addEventListener('DOMContentLoaded', init);
</script>
