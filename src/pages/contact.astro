---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us - Ultimate Bench">
    <main>
        <h1 id="contact-title">Contact Us</h1>
        <div class="contact-container">
            <p>If you have any questions, concerns, or feedback regarding Ultimate Bench, please feel free to reach out to us.</p>

            <div class="contact-methods">
                <div class="contact-method">
                    <h2>Email Support</h2>
                    <p>For general inquiries and support, please email us at:</p>
                    <a href="mailto:support@ultimate-bench.com" class="email-link">support@ultimate-bench.com</a>
                </div>
            </div>
        </div>
    </main>
</Layout>

<style>
    main {
        max-width: 50rem;
        margin: 4rem auto;
        padding: 0 1rem;
    }

    h1 {
        font-size: 2.5rem;
        font-weight: 900;
        text-align: center;
        margin-bottom: 2rem;
        color: white;
    }

    .contact-container {
        background: rgba(31, 41, 55, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 1rem;
        padding: 2.5rem;
        color: #D1D5DB;
        line-height: 1.8;
        text-align: center;
    }

    .contact-methods {
        margin-top: 2rem;
        display: flex;
        justify-content: center;
    }

    .contact-method {
        background: rgba(17, 24, 39, 0.6);
        padding: 2rem;
        border-radius: 0.5rem;
        border: 1px solid rgba(96, 165, 250, 0.3);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    .contact-method h2 {
        font-size: 1.5rem;
        color: #fff;
        margin-top: 0;
        margin-bottom: 1rem;
        font-weight: 700;
    }

    .email-link {
        display: inline-block;
        margin-top: 1rem;
        font-size: 1.25rem;
        font-weight: 600;
        color: #60A5FA;
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .email-link:hover {
        color: #93C5FD;
        text-decoration: underline;
    }
</style>
