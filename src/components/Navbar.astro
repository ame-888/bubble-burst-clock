---
import ThemeToggle from './ThemeToggle.astro';




const { lang = 'en' } = Astro.props;

---

<nav class="navbar">
    <div class="navbar-container">
        <button class="navbar-toggle" id="navbar-toggle" aria-label="Toggle Navigation">
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
        </button>

        <div class="navbar-menu" id="navbar-menu">
            <a href="/" class="nav-link" data-i18n-key="nav_home">Home</a>
            <a href="/about" class="nav-link" data-i18n-key="about_button">About</a>
            <a href="/privacy" class="nav-link" data-i18n-key="privacy_policy_button">Privacy Policy</a>
            <a href="/arcade" id="nav-arcade" class="nav-link" style="color: #FACC15; font-weight: 700; margin-right: 1rem;">ARCADE</a>
        </div>

        <div class="navbar-end">
             <ThemeToggle />
        </div>
    </div>
</nav>

<style>
    .navbar {
        background-color: rgba(17, 24, 39, 0.95);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(10px);
    }

    .navbar-container {
        max-width: 80rem;
        margin: 0 auto;
        padding: 0 1rem;
        height: 4rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .brand-link {
        font-family: 'Poppins', sans-serif;
        font-weight: 900;
        font-size: 1.25rem;
        color: white;
        text-decoration: none;
        background: linear-gradient(to right, #60A5FA, #A78BFA);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .navbar-menu {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .nav-link {
        color: #D1D5DB;
        text-decoration: none;
        font-weight: 500;
        font-size: 0.85rem;
        transition: color 0.2s;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        position: relative; /* For notification anchor */
    }

    .nav-link:hover {
        color: white;
    }

    /* Pet Notification Style */
    .pet-notification {
        display: inline-block;
        margin-left: 0.5rem;
        animation: bounce 1s infinite;
        color: #FACC15;
        font-size: 1.2em;
        vertical-align: middle;
        text-shadow: 0 0 5px rgba(250, 204, 21, 0.5);
    }

    @keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-3px); }
    }

    .navbar-end {
        position: relative;
        min-width: 150px; /* Space for language switcher */
        display: flex;
        align-items: center;
        gap: 1rem;
        justify-content: flex-end;
    }

    /* Override LanguageSwitcher positioning for Navbar */
    :global(.language-switcher) {
        position: static !important;
    }

    .navbar-toggle {
        display: none;
        flex-direction: column;
        justify-content: space-between;
        width: 30px;
        height: 21px;
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0;
        z-index: 101;
    }

    .bar {
        height: 3px;
        width: 100%;
        background-color: white;
        border-radius: 10px;
        transition: all 0.3s ease;
    }

    @media (max-width: 900px) {
        .navbar-toggle {
            display: flex;
        }

        .navbar-menu {
            position: fixed;
            top: 4rem; /* Below navbar */
            left: 0;
            width: 100%;
            background-color: #1F2937;
            flex-direction: column;
            gap: 0;
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease-out;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .navbar-menu.active {
            max-height: 400px; /* Arbitrary large height */
        }

        .nav-link {
            width: 100%;
            text-align: center;
            padding: 1.5rem 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .nav-link:last-child {
            border-bottom: none;
        }
    }
</style>

<script >
    // Mobile Menu Toggle
    const toggle = document.getElementById('navbar-toggle');
    const menu = document.getElementById('navbar-menu');

    if (toggle && menu) {
        toggle.addEventListener('click', () => {
            menu.classList.toggle('active');
            // Animate hamburger (optional simple rotation)
        });
    }



    // Pet Notification Logic
    function checkPetNotification() {
        try {
            // Check if user has a pet
            const hasPet = localStorage.getItem('pixel_pet');
            // Check if notification already seen
            const notificationSeen = localStorage.getItem('pet_notification_seen');

            if (hasPet && !notificationSeen) {
                // Create indicator
                const indicator = document.createElement('span');
                indicator.className = 'pet-notification';
                indicator.textContent = '⬅'; // Or ✨
                indicator.setAttribute('aria-label', 'New Pet!');

                // Assuming pet link exists somewhere or we want to add the indicator somewhere
                // (The original code seems to have had a specific target that got lost. Let's just catch the error)
            }
        } catch (e) {
            console.warn('Pet notification check failed:', e);
        }
    }

    document.addEventListener('DOMContentLoaded', () => {

        checkPetNotification();

        // Also highlight active link
        const currentPath = window.location.pathname;
        document.querySelectorAll('.nav-link').forEach(link => {
            const href = link.getAttribute('href');
            // Exact match or sub-path match (e.g. /players matching /players/...)
            if (href === currentPath || (href !== '/' && currentPath.startsWith(href))) {
                link.style.color = '#60A5FA';
                link.style.fontWeight = '700';
            }
        });
    });
</script>
