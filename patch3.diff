        // Sorting and DOM update logic
        const getVal = (val) => (typeof val === 'number' ? val : 0);

        function calculateScores(item, keys, method) {
            const scores = keys.map(k => getVal(item[k]));
            if (method === 'baseline') {
                return scores; // We'll handle this specially in the sorter
            } else if (method === 'average') {
                const sum = scores.reduce((a, b) => a + b, 0);
                return sum / keys.length;
            } else if (method === 'crucible') {
                return scores.reduce((sum, score, i) => sum + (score * (i + 1)), 0);
            } else if (method === 'resilience') {
                const lvl1Score = scores[0];
                if (lvl1Score === 0) return 0;
                let hardestScore = 0;
                // Find the hardest level the model attempted (not unavailable or invalid)
                // Assuming scores array maps directly to difficulty levels 1 -> N
                for (let i = keys.length - 1; i >= 0; i--) {
                   const key = keys[i];
                   if (typeof item[key] === 'number') {
                       hardestScore = item[key];
                       break;
                   }
                }
                return (hardestScore / lvl1Score) * 100;
            }
            return 0;
        }

        function sortAndRank(rawList, keys, method) {
            let list = [...rawList];

            // Re-evaluate fails based on keys
            list.forEach(item => {
                item.isTotalFail = keys.every(key => getVal(item[key]) === 0);
                item._sortValue = calculateScores(item, keys, method);
            });

            let sorted = list.sort((a, b) => {
                if (method === 'baseline') {
                    for (const key of keys) {
                        const valA = getVal(a[key]);
                        const valB = getVal(b[key]);
                        if (valB !== valA) return valB - valA;
                    }
                    return 0;
                } else {
                    return b._sortValue - a._sortValue;
                }
            });

            const eligible = sorted.filter(i => !i.isTotalFail);
            const fails = sorted.filter(i => i.isTotalFail).sort((a,b) => a.name.localeCompare(b.name));

            // Ranking
            let currentRank = 1;
            let previousItem = null;
            let rankedItems = [];

            eligible.forEach((item) => {
                if (previousItem !== null) {
                    let isWorse = false;
                    if (method === 'baseline') {
                        for (const key of keys) {
                            const itemVal = getVal(item[key]);
                            const prevVal = getVal(previousItem[key]);
                            if (itemVal < prevVal) {
                                isWorse = true;
                                break;
                            } else if (itemVal > prevVal) {
                                break;
                            }
                        }
                    } else {
                        if (item._sortValue < previousItem._sortValue) {
                            isWorse = true;
                        }
                    }

                    if (isWorse) {
                        currentRank++;
                    }
                }
                item.rank = currentRank;
                rankedItems.push(item);
                previousItem = item;
            });

            fails.forEach(item => {
                item.rank = 'INVALID';
                rankedItems.push(item);
            });

            return rankedItems;
        }

